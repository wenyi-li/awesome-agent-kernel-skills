+        x_amax = x.abs().float().amax(dim=3, keepdim=True).clamp(1e-4)
+        sf = x_amax / 448.0
+        x_scaled = (x * (1.0 / sf)).to(torch.float8_e4m3fn)
+        x_cast_back = x_scaled.float() * sf
+
