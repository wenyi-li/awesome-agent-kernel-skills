// origin: wiki/kernels/nvfp4-gemv.md Phase 3 variant (copied from the extracted blog bundle)

// Extracted from sources/blogs/yue-nvfp4-hackathon.md by scripts/extract_blog_code.py
// Heading: # Blackwell NVFP4 Kernel Hackathon Journey (Yue Zhang) > ## Key Optimization Steps > ### Step 4: PTX Assembly (~27us)
// Original fence language: asm
// See artifacts/blogs/yue-nvfp4-hackathon/code/PROVENANCE.yaml for origin + license metadata.

// Key PTX optimizations:
// 1. cvt.rn.f16x2.e2m1x2 for FP4 conversion (vs C intrinsic)
cvt.rn.f16x2.e2m1x2 %result, %fp4_packed;

// 2. Byte unpacking via mov.b32 (vs bitwise shift/mask)
mov.b32 {b0, b1, b2, b3}, %packed_word;
// Splits 32-bit word into 4 bytes without arithmetic

// 3. Cache-qualified loads
ld.global.L1::no_allocate.v4.u64 {a0,a1,a2,a3}, [addr_a];  // stream A
ld.global.L1::evict_last.v4.u64 {b0,b1,b2,b3}, [addr_b];   // keep B hot
